<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/AppTheme">

        <activity
            android:configChanges="orientation|keyboardHidden|keyboard|screenSize|locale|smallestScreenSize|screenLayout|uiMode|navigation"
            android:name=".MainActivity"
            android:label="@string/title_activity_main"
            android:theme="@style/AppTheme.NoActionBarLaunch"
            android:launchMode="singleTask"
            android:exported="true">

            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

            <!-- Open an exported route with Route Spoofer: "Open with" from a file
                 manager / Downloads / Drive, and the system share sheet. Without these
                 the app exports a .json it cannot itself be asked to open. -->
            <intent-filter android:label="@string/import_route">
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="content" />
                <data android:scheme="file" />
                <data android:mimeType="application/json" />
                <data android:mimeType="text/json" />
            </intent-filter>

            <!-- Same file coming from a share sheet ("Share → Route Spoofer"). -->
            <intent-filter android:label="@string/import_route">
                <action android:name="android.intent.action.SEND" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:mimeType="application/json" />
                <data android:mimeType="text/json" />
            </intent-filter>

            <!-- Pre-Android-10 file managers hand a .json out as octet-stream / plain
                 text, so those two are matched by extension as well. pathPattern only
                 bites on URIs with a real path, which is what those senders provide. -->
            <intent-filter android:label="@string/import_route">
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="content" />
                <data android:scheme="file" />
                <data android:host="*" />
                <data android:mimeType="application/octet-stream" />
                <data android:mimeType="text/plain" />
                <data android:pathPattern=".*\\.json" />
                <data android:pathPattern=".*\\..*\\.json" />
                <data android:pathPattern=".*\\..*\\..*\\.json" />
            </intent-filter>

        </activity>

        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths"></meta-data>
        </provider>

        <!-- Foreground service that owns the playback clock + mock injection.
             It does NOT consume the device's location (it never reads a real
             GPS fix); it INJECTS scripted fixes into the OS test providers, so
             the standard "location" FGS type does not apply. "specialUse" is the
             correct type, justified by the property below. -->
        <service
            android:name=".MockLocationService"
            android:exported="false"
            android:foregroundServiceType="specialUse">
            <property
                android:name="android.app.PROPERTY_SPECIAL_USE_FGS_SUBTYPE"
                android:value="Replays a user-defined route by injecting a scripted, moving mock GPS location into the Android test location providers at a set speed, so location-based apps can be tested without physically moving. The foreground service keeps emitting the route while the app is backgrounded." />
        </service>
    </application>

    <!-- Permissions -->

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SPECIAL_USE" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <!-- Required for the app to appear in Developer options' "Select mock
         location app" picker. Not granted at runtime; selecting the app in
         dev options is what authorizes mock injection. -->
    <uses-permission android:name="android.permission.ACCESS_MOCK_LOCATION"
        tools:ignore="MockLocation,ProtectedPermissions" />
</manifest>
